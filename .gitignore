__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.eggs/

# --- Test / lint caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml

# --- Personal development setup docs (machine-specific paths) ---
docs/cross-platform-git-setup.md

# --- OneDrive artifacts and conflict copies ---
# No machine-name patterns here: keep this file free of personal identifiers.
# state/*.age is a superset of state/*.md.age etc. and also covers OneDrive
# conflict-copy variants (e.g. state/foo.md-MACHINENAME.age).
*conflicted*
state/*.age
.DS_Store

# --- IDE settings ---
.vscode/

# --- AI CLI internal scratch files (Gemini, etc.) ---
.gemini_security/
.gemini/

# --- Archive and working directories ---
.archive/
.claude/
tmp/
visuals/

# --- Assembled instruction file (contains personal identity) ---
config/Artha.md

# --- Artha reference docs extracted from Artha.core.md (employer-specific tool references) ---
config/Artha.reference.md

# --- WorkIQ and platform overlays (employer-specific integration configs) ---
config/overlays/*.md

# --- Reflect protocol (contains PII: personal email alias, employer info) ---
config/reflect-protocol.md

# --- Work OS scripts (contain employer-specific config references) ---
# The public repo ships example/framework code; actual work scripts with
# employer-specific connector wiring are local-only.
scripts/work_loop.py
scripts/work_bootstrap.py
scripts/work_warm_start.py
scripts/work_domain_writers.py
scripts/work_reader.py
scripts/work_notes.py
scripts/work/

# --- Work OS tests (import above gitignored work scripts) ---
tests/work/

# --- External agent drop folder, registry, and work-specific agent configs ---
# These contain personal work context (team names, ADO IDs, tool-specific instructions)
# Only the 3 canonical artha-work*.md agent definitions (already tracked) are public.
config/agents/external/
config/agents/external-registry.yaml
config/agents/*.agent.md

# --- VS Code agent discovery shims for internal/work-specific agents ---
# .github/agents/ is scanned by VS Code for runSubagent() — files must exist locally.
# Only artha-work-*.md (3 canonical files, already tracked) are public.
# Any agent embedding internal service names (SDP, XPF, OneDeploy, IcM, etc.) is gitignored.
.github/agents/storage-*.md
.github/agents/*-expert.md
.github/agents/*-advisor.md
.github/agents/*-analyst.md
.github/agents/icm-*.md
.github/agents/xpf-*.md
.github/agents/ado-*.md
.github/agents/kusto-*.md

# --- Decrypted state transient files ---
.artha-decrypted

# --- Runtime lock and ephemeral files ---
.artha-op-lock
*.bak
state/*.bak*
state/.preflight_write_test
state/*.lock
state/*.yaml.age.*
state/*.md.age.*

# --- OneDrive conflict copies ---
# OneDrive git-shadow directory (sync artefact)
.git 2/
*.pre-*-bak

# --- Career Search PII files (specs/career-ops.md §7.4 security requirements) ---
# cv.md and article-digest.md contain PII — NEVER commit to git
# Store at ~/.artha-local/cv.md (outside repo) — root-level fallback location protected here
cv.md
article-digest.md
# Compiled fonts (binary — generated by scripts/install_fonts.sh)
fonts/*.woff2
fonts/*.woff
fonts/*.ttf

# --- Career Search generated outputs (personal data — never committed) ---
# Entire directories are gitignored — CI creates them via mkdir -p
output/career/
briefings/career/
# Career audit trace (JSONL — covered by *.jsonl above, but explicit for clarity)
state/career_audit.jsonl
# Local career cache (~/.artha-local/career/ is outside repo — already safe)

# --- Obsidian vault (personal notes — never committed) ---
.obsidian/

# --- OneNote export folder (personal — never committed) ---
OneNote/

# --- AI Studio skill packages and local skill directory ---
# home-intelligence.skill and skills/ contain personal entity names
# (camera names, family member names from Home Assistant) — never committed
*.skill
skills/
# But scripts/skills/ is the Python skill module (no PII) — commit it
!scripts/skills/
