# --- User data (NEVER committed) ---
# Personal profile - created by /bootstrap
config/user_profile.yaml
# To Do list IDs - generated at setup
config/artha_config.yaml
# Legacy config - consolidated into user_profile.yaml
config/settings.md
# User-specific sender->domain routing
config/routing.yaml
# Generated Identity block - personal data
config/Artha.identity.md
# Channel bridge live config — contains recipient IDs (PII)
config/channels.yaml
# User-specific connector config — contains credential key names and token paths
config/connectors.yaml
config/connectors.yaml.bak
# Channel push artifacts (ephemeral, machine-local)
state/.channel_push_marker_*.json
state/.channel_listener.pid
state/.pending_pushes/
# Bridge drop-files (ephemeral; synced via OneDrive, not Git)
state/.action_bridge/
# User-specific prompt extensions
config/prompt-overlays/*.md
# Keep the README
!config/prompt-overlays/README.md

# --- Local archive (personal specs, notes with PII — never committed) ---
.archive/
knowledge/
autoresearch/
ai-demo-day/

# --- Specs directory — only canonical specs are committed ---
# All specs/ files are ignored by default; only the 3 canonical specs are
# whitelisted below. Working/draft specs stay local.
specs/*
!specs/artha-prd.md
!specs/artha-tech-spec.md
!specs/artha-ux-spec.md

# --- State files (all user-generated, ALL subdirectories) ---
state/*.md
state/*.md.age
state/*.yaml
state/*.yaml.age
# JSON runtime state (skills cache, catch-up run history — personal data, not committed)
state/*.json
state/*.json.age
# Work OS state — personal work data (never committed)
state/work/
# Bridge artifacts — aggregate signals with potential PII (never committed)
state/bridge/
# Eval files — test evaluation data
state/work/eval/
# SQLite databases (actions.db, etc.) — user data, not committed
state/*.db
state/*.db-shm
state/*.db-wal
!state/.gitkeep
!state/templates/

# --- GFS backup snapshots (ZIP-per-day, stored at project root) ---
backups/

# --- Ved Dev Kit (personal framework, prompt history — not synced) ---
ved-dev-kit/

# --- Briefing and summary archives ---
briefings/
summaries/

# --- Email archives and raw review files ---
emails_*.jsonl
review_*.txt
*.jsonl
!tests/fixtures/*.jsonl
!tests/fixtures/**/*.jsonl
gmail_*.jsonl
icloud_*.jsonl
outlook_*.jsonl
*_errors.txt
*_err.txt
# filesystem write probe
test-write.txt
# test runner output artifact
test_out.txt
# Work OS test artifacts — generated output, not source
tests/work/_pytest_results.txt
# Scratch test runner scripts (local dev tools, not part of public repo)
run_tests.ps1
run_tests.py
run_tests2.py
scripts/_run_tests_internal.py

# --- Token and credential files ---
.tokens/
*.token.json

# --- Virtual environments ---
.venv/
.venv-win/

# --- Python bytecode ---
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.eggs/

# --- Test / lint caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml

# --- Personal development setup docs (machine-specific paths) ---
docs/cross-platform-git-setup.md

# --- OneDrive artifacts and conflict copies ---
# No machine-name patterns here: keep this file free of personal identifiers.
# state/*.age is a superset of state/*.md.age etc. and also covers OneDrive
# conflict-copy variants (e.g. state/foo.md-MACHINENAME.age).
*conflicted*
state/*.age
.DS_Store

# --- IDE settings ---
.vscode/

# --- Archive and working directories ---
.archive/
.claude/
tmp/
visuals/

# --- Assembled instruction file (contains personal identity) ---
config/Artha.md

# --- External agent drop folder, registry, and work-specific agent configs ---
# These contain personal work context (team names, ADO IDs, tool-specific instructions)
# Only the 3 canonical artha-work*.md agent definitions (already tracked) are public.
config/agents/external/
config/agents/external-registry.yaml
config/agents/*.agent.md

# --- Decrypted state transient files ---
.artha-decrypted

# --- Runtime lock and ephemeral files ---
.artha-op-lock
*.bak
state/*.bak*
state/.preflight_write_test
state/*.lock
state/*.yaml.age.*
state/*.md.age.*

# --- OneDrive conflict copies ---
# OneDrive git-shadow directory (sync artefact)
.git 2/
*.pre-*-bak
