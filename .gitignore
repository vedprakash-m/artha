# ─── User data (NEVER committed) ─────────────────────────────────────────────
config/user_profile.yaml          # Personal profile — created by /bootstrap
config/artha_config.yaml          # To Do list IDs — generated at setup
config/settings.md                # Legacy config — consolidated into user_profile.yaml
config/routing.yaml               # User-specific sender→domain routing
config/Artha.identity.md          # Generated §1 Identity block — personal data
config/prompt-overlays/*.md       # User-specific prompt extensions
!config/prompt-overlays/README.md # Keep the README

# ─── State files (all user-generated) ────────────────────────────────────────
state/*.md
state/*.md.age
!state/.gitkeep
!state/templates/

# ─── Briefing and summary archives ───────────────────────────────────────────
briefings/
summaries/

# ─── Email archives and raw review files ─────────────────────────────────────
emails_*.jsonl
review_*.txt
*.jsonl
gmail_*.jsonl
icloud_*.jsonl
outlook_*.jsonl
*_errors.txt
*_err.txt

# ─── Token and credential files ──────────────────────────────────────────────
.tokens/
*.token.json
~/.artha-tokens/

# ─── Virtual environments ────────────────────────────────────────────────────
.venv/
.venv-win/

# ─── Python bytecode ─────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.eggs/

# ─── Test / lint caches ──────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml

# ─── OneDrive artifacts ──────────────────────────────────────────────────────
*conflicted*
.DS_Store

# ─── IDE settings ────────────────────────────────────────────────────────────
.vscode/

# ─── Archive and working directories ─────────────────────────────────────────
.archive/
.claude/
tmp/
visuals/

# ─── Spec files (fictional example data — safe to commit) ────────────────────
# specs/ — no longer excluded; PII scrub completed, names are fictional examples

# ─── Assembled instruction file (contains personal identity) ─────────────────
config/Artha.md

# ─── Decrypted state transient files ─────────────────────────────────────────
.artha-decrypted
