# --- User data (NEVER committed) ---
# Personal profile - created by /bootstrap
config/user_profile.yaml
# To Do list IDs - generated at setup
config/artha_config.yaml
# Legacy config - consolidated into user_profile.yaml
config/settings.md
# User-specific sender->domain routing
config/routing.yaml
# Generated Identity block - personal data
config/Artha.identity.md
# Channel bridge live config — contains recipient IDs (PII)
config/channels.yaml
# Channel push artifacts (ephemeral, machine-local)
state/.channel_push_marker_*.json
state/.channel_listener.pid
state/.pending_pushes/
# Bridge drop-files (ephemeral; synced via OneDrive, not Git)
state/.action_bridge/
# User-specific prompt extensions
config/prompt-overlays/*.md
# Keep the README
!config/prompt-overlays/README.md

# --- Local archive (personal specs, notes with PII — never committed) ---
.archive/

# --- State files (all user-generated, ALL subdirectories) ---
state/*.md
state/*.md.age
state/*.yaml
state/*.yaml.age
# Work OS state — personal work data (never committed)
state/work/
# Bridge artifacts — aggregate signals with potential PII (never committed)
state/bridge/
# Eval files — test evaluation data
state/work/eval/
# SQLite databases (actions.db, etc.) — user data, not committed
state/*.db
state/*.db-shm
state/*.db-wal
!state/.gitkeep
!state/templates/

# --- GFS backup snapshots (ZIP-per-day, stored at project root) ---
backups/

# --- Ved Dev Kit (personal framework, prompt history — not synced) ---
ved-dev-kit/

# --- Briefing and summary archives ---
briefings/
summaries/

# --- Email archives and raw review files ---
emails_*.jsonl
review_*.txt
*.jsonl
!tests/fixtures/*.jsonl
!tests/fixtures/**/*.jsonl
gmail_*.jsonl
icloud_*.jsonl
outlook_*.jsonl
*_errors.txt
*_err.txt
# filesystem write probe
test-write.txt
# test runner output artifact
test_out.txt
# Work OS test artifacts — generated output, not source
tests/work/_pytest_results.txt
# Scratch test runner scripts (local dev tools, not part of public repo)
run_tests.ps1
run_tests.py
run_tests2.py
scripts/_run_tests_internal.py

# --- Token and credential files ---
.tokens/
*.token.json

# --- Virtual environments ---
.venv/
.venv-win/

# --- Python bytecode ---
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.eggs/

# --- Test / lint caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml

# --- Personal development setup docs (machine-specific paths) ---
docs/cross-platform-git-setup.md

# --- OneDrive artifacts ---
*conflicted*
.DS_Store

# --- Spec working files (only main specs committed: PRD, Tech, UX) ---
specs/*.md
!specs/artha-prd.md
!specs/artha-tech-spec.md
!specs/artha-ux-spec.md

# --- IDE settings ---
.vscode/

# --- Archive and working directories ---
.archive/
.claude/
tmp/
visuals/

# --- Assembled instruction file (contains personal identity) ---
config/Artha.md

# --- Decrypted state transient files ---
.artha-decrypted

# --- Runtime lock and ephemeral files ---
.artha-op-lock
*.bak
state/.preflight_write_test
state/*.lock
state/*.yaml.age.*
state/*.md.age.*

# --- OneDrive conflict copies ---
*-CPC-vemis-DJD0M*
".git 2/"
*.pre-*-bak
