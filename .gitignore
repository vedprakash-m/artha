# --- User data (NEVER committed) ---
# Personal profile - created by /bootstrap
config/user_profile.yaml
# To Do list IDs - generated at setup
config/artha_config.yaml
# Legacy config - consolidated into user_profile.yaml
config/settings.md
# User-specific sender->domain routing
config/routing.yaml
# Generated Identity block - personal data
config/Artha.identity.md
# Channel bridge live config — contains recipient IDs (PII)
config/channels.yaml
# OpenClaw Home Bridge config — contains LAN endpoint URL and bot name (personal infra; never committed)
config/claw_bridge.yaml
config/claw_bridge.yaml.bak
# User-specific connector config — contains credential key names and token paths
config/connectors.yaml
config/connectors.yaml.bak
# Per-domain autonomy levels — runtime user state (trip history, cooldown dates)
config/domain_autonomy_state.yaml
# Watch monitor keyword config — contains personal interest topics (immigration, finance, etc.)
config/watches.yaml
# Channel push artifacts (ephemeral, machine-local)
state/.channel_push_marker_*.json
state/.channel_listener.pid
state/.channel_listener.heartbeat
state/.pending_pushes/
# Bridge drop-files (ephemeral; synced via OneDrive, not Git)
state/.action_bridge/
# User-specific prompt extensions
config/prompt-overlays/*.md
# Keep the README
!config/prompt-overlays/README.md

# --- Local archive (personal specs, notes with PII — never committed) ---
.archive/
knowledge/
ai-demo-day/
obsidian/

# --- Specs directory — only canonical specs are committed ---
# All specs/ files are ignored by default; only the 3 canonical specs are
# whitelisted below. Working/draft specs stay local.
specs/*
!specs/artha-prd.md
!specs/artha-tech-spec.md
!specs/artha-ux-spec.md

# --- State files (all user-generated, ALL subdirectories) ---
state/*.md
state/*.md.age
state/*.yaml
state/*.yaml.age
# JSON runtime state (skills cache, catch-up run history — personal data, not committed)
state/*.json
state/*.json.age
# Content directory — posts, drafts, voice profile, gallery, radar backlog (never committed)
state/content/
# Work OS state — personal work data (never committed)
state/work/
# Bridge artifacts — aggregate signals with potential PII (never committed)
state/bridge/
# Eval files — test evaluation data
state/work/eval/
# SQLite databases (actions.db, etc.) — user data, not committed
state/*.db
state/*.db-shm
state/*.db-wal
# Reasoning traces — per-session LLM reasoning (harden.md §5.1); PII-scrubbed but local-only
state/traces/
# Connector health/state subdirectory (harden.md §2.3.1; last_fetched_at timestamps)
state/connectors/
# KB audit log (LLM observability — machine-local, never committed)
state/audit/
!state/.gitkeep
!state/templates/

# --- GFS backup snapshots (ZIP-per-day, stored at project root) ---
backups/

# --- Briefing and summary archives ---
# Daily briefing files are personal (never committed)
briefings/*.md
briefings/career/
summaries/

# --- Email archives and raw review files ---
# Inbox sync directory (raw email/calendar data ingested by inbox_process.py — personal, never committed)
inbox/
emails_*.jsonl
review_*.txt
*.jsonl
!tests/fixtures/*.jsonl
!tests/fixtures/**/*.jsonl
gmail_*.jsonl
icloud_*.jsonl
outlook_*.jsonl
*_errors.txt
*_err.txt
