[Unit]
Description=Artha Vault Watchdog — re-encrypt stale plaintext vault files after abnormal exit
Documentation=https://github.com/vedmis/artha

[Service]
Type=oneshot
# Uses ARTHA_DIR resolved from the script itself — no hardcoded paths here.
ExecStart=%h/.artha-local/vault_watchdog_linux.sh
# Capture any output to the journal
StandardOutput=journal
StandardError=journal
# Do not fail the timer if this service fails transiently
SuccessExitStatus=0 1
